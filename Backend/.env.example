# ─── Base de datos ───
# Para Supabase usa el Session Pooler (puerto 5432) si tu red no soporta IPv6.
# Ejemplo: postgres://prisma.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ─── JWT ───
JWT_SECRET="your_super_secure_secret_here"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Servidor ───
PORT=3000
NODE_ENV=development

# —— Autenticación segura (RF01) ——
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MINUTES=30

# —— Respaldos en nube (RF10) ——
BACKUP_CLOUD_ENABLED=false
# BACKUP_CLOUD_UPLOAD_URL=https://your-endpoint.com/upload
# BACKUP_CLOUD_AUTH_TOKEN=your_token_here
